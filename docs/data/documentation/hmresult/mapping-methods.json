{"hierarchy":{"paths":[["doc:\/\/HMResult\/documentation\/HMResult","doc:\/\/HMResult\/documentation\/HMResult\/Swift\/Result"]]},"sections":[],"identifier":{"url":"doc:\/\/HMResult\/documentation\/HMResult\/Mapping-Methods","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"title":"Mapping Methods","roleHeading":"API Collection","modules":[{"name":"HMResult"}],"role":"collectionGroup"},"topicSections":[{"identifiers":["doc:\/\/HMResult\/documentation\/HMResult\/Swift\/Result\/flatMap(_:)","doc:\/\/HMResult\/documentation\/HMResult\/Swift\/Result\/flatMapAndMergeError(_:)","doc:\/\/HMResult\/documentation\/HMResult\/Swift\/Result\/map(_:)","doc:\/\/HMResult\/documentation\/HMResult\/Swift\/Result\/mapAndMergeError(_:)","doc:\/\/HMResult\/documentation\/HMResult\/Swift\/Result\/mapFailureToSuccess(_:)","doc:\/\/HMResult\/documentation\/HMResult\/Swift\/Result\/mapFailureToSuccessAndErrorToFailure(_:)"],"anchor":"Topics"}],"primaryContentSections":[{"kind":"content","content":[{"level":5,"text":"General transformation","anchor":"General-transformation","type":"heading"},{"inlineContent":[{"type":"text","text":"Transforming a value, by applying a function to it using dot syntax, is sometimes an easier-to-read way to write code, and probably ought to be available on "},{"type":"emphasis","inlineContent":[{"text":"every type","type":"text"}]},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["func transform<Transformed, Error>(","  _ transform: (Self) throws(Error) -> Transformed",") throws(Error) -> Transformed {","  try transform(self)","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"But that’s not specific to "},{"type":"codeVoice","code":"Result"},{"type":"text","text":", and is not included in this package."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"We "},{"type":"emphasis","inlineContent":[{"text":"could","type":"text"}]},{"type":"text","text":" restrict the transformation to require mapping similar types of "},{"code":"Result","type":"codeVoice"},{"type":"text","text":"s, such as"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"Result<Int, Never>","type":"codeVoice"},{"text":" ➡️ ","type":"text"},{"code":"Result<String, any Error>","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"That would look like this:","type":"text"}]},{"code":["func transform<NewSuccess, NewFailure, Error>(","  _ transform: (Self) throws(Error) -> Result<NewSuccess, NewFailure>",") throws(Error) -> Result<NewSuccess, NewFailure> {","  try transform(self)","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Even with this new restriction, the possibilities are so vast in what can be accomplished there, that it’s not worth creating a function for. And so again, this "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" is not included in this package either."}]},{"type":"heading","text":"flatMap","anchor":"flatMap","level":3},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flatMap"},{"text":" is the closest to a general-purpose ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" method that this package works with. The capabilities are different in only two respects:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"flatMap","type":"codeVoice"},{"type":"text","text":"‘s’ "},{"code":"transform","type":"codeVoice"},{"type":"text","text":" closure operates only on a wrapped value, instead of an entire "},{"code":"Result","type":"codeVoice"},{"type":"text","text":" instance."}]}]},{"content":[{"inlineContent":[{"code":"flatMap","type":"codeVoice"},{"type":"text","text":" cannot modify the wrapped error type."}],"type":"paragraph"}]}]},{"type":"thematicBreak"},{"type":"paragraph","inlineContent":[{"text":"The “","type":"text"},{"code":"flat","type":"codeVoice"},{"text":"” in ","type":"text"},{"code":"flatMap","type":"codeVoice"},{"text":" refers to the way that it introduces no more “nesting” than the ","type":"text"},{"code":"Result","type":"codeVoice"},{"text":" represented before transformation. For example,","type":"text"}]},{"code":["Result<String, Never>.flatMap"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":", when supplied with a ","type":"text"},{"code":"transform","type":"codeVoice"},{"text":" closure returning type","type":"text"}]},{"code":["Result<Int, Never>"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":", will return","type":"text"}]},{"code":["Result<Int, Never>"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":", as opposed to an “unflattened”","type":"text"}]},{"code":["Result<Result<Int, Never>, Never>"],"type":"codeListing","syntax":"swift"},{"type":"thematicBreak"},{"type":"paragraph","inlineContent":[{"overridingTitle":"As documented below","overridingTitleInlineContent":[{"text":"As documented below","type":"text"}],"identifier":"doc:\/\/HMResult\/documentation\/HMResult\/Swift\/Result\/flatMap(_:)","type":"reference","isActive":true},{"type":"text","text":", "},{"type":"codeVoice","code":"flatMap"},{"type":"text","text":" will not throw an error when the transformed "},{"type":"codeVoice","code":"Result"},{"type":"text","text":" is a "},{"type":"codeVoice","code":"failure"},{"type":"text","text":", but it will throw an error if the transformation throws an error."}]},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/result\/flatMap(_:)","type":"reference","isActive":true},{"text":" nearly gets ","type":"text"},{"code":"flatMap","type":"codeVoice"},{"text":" right, but it does not incorporate throwing an error. This version should be deprecated.","type":"text"}]},{"type":"heading","text":"flatMapAndMergeError","anchor":"flatMapAndMergeError","level":3},{"type":"paragraph","inlineContent":[{"text":"This is a special case of ","type":"text"},{"code":"flatMap","type":"codeVoice"},{"text":". If ","type":"text"},{"code":"transform","type":"codeVoice"},{"text":" throws the untransformed ","type":"text"},{"code":"Result","type":"codeVoice"},{"text":"’s ","type":"text"},{"code":"Failure","type":"codeVoice"},{"text":" type, the error can be forwarded into the transformed wrapper type, rather than being thrown from ","type":"text"},{"code":"flatMap","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both forms are useful. Naming this differently than "},{"code":"flatMap","type":"codeVoice"},{"type":"text","text":" is necessary because it would not be enough, for the compiler, to just add "},{"code":"try","type":"codeVoice"},{"type":"text","text":" in front of another "},{"code":"flatMap","type":"codeVoice"},{"type":"text","text":" overload."}]},{"type":"heading","text":"map","anchor":"map","level":3},{"type":"paragraph","inlineContent":[{"text":"The only difference between ","type":"text"},{"type":"codeVoice","code":"flatMap"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"map"},{"text":" is that map’s ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" closure returns a wrapped value, not a wrapper. Thusly, no “flattening” is necessary.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As with "},{"code":"flatMap","type":"codeVoice"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/result\/map(_:)"},{"type":"text","text":" nearly gets "},{"code":"map","type":"codeVoice"},{"type":"text","text":" right, but it does not incorporate throwing an error. This version should be deprecated."}]},{"type":"heading","text":"mapAndMergeError","anchor":"mapAndMergeError","level":3},{"type":"paragraph","inlineContent":[{"text":"This is to ","type":"text"},{"code":"map","type":"codeVoice"},{"text":" as ","type":"text"},{"code":"flatMapAndMergeError","type":"codeVoice"},{"text":" is to ","type":"text"},{"code":"flatMap","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"heading","text":"flatMapFailure","anchor":"flatMapFailure","level":4},{"type":"paragraph","inlineContent":[{"text":"This is the same idea as ","type":"text"},{"code":"flatMap","type":"codeVoice"},{"text":", except, with a transformation of the wrapper’s ","type":"text"},{"code":"Failure","type":"codeVoice"},{"text":" type, rather than its ","type":"text"},{"code":"Value","type":"codeVoice"},{"text":" type.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As we’ve seen above with "},{"type":"codeVoice","code":"flatMap"},{"type":"text","text":" and "},{"type":"codeVoice","code":"map"},{"type":"text","text":", the standard library nearly gets this right, under the problematic* name "},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/result\/flatMapError(_:)"},{"type":"text","text":", but it does not incorporate throwing an error. It "},{"type":"emphasis","inlineContent":[{"text":"should","type":"text"}]},{"type":"text","text":", for completeness, but does anyone need that? 🤔 (It won’t be included in this package until we hear that they do.)"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"* It’s problematic because the failure type, while restricted to be an error, is called "},{"code":"Failure","type":"codeVoice"},{"type":"text","text":", not "},{"code":"Error","type":"codeVoice"},{"type":"text","text":". And it’s not clear whether you’re mapping a failure enumeration case, or an error occurring from the transformation closure."}]},{"type":"heading","text":"mapFailure","anchor":"mapFailure","level":4},{"type":"paragraph","inlineContent":[{"text":"This is to ","type":"text"},{"type":"codeVoice","code":"flatMapFailure"},{"text":" as ","type":"text"},{"type":"codeVoice","code":"map"},{"text":" is to ","type":"text"},{"type":"codeVoice","code":"flatMap"},{"text":".","type":"text"}]},{"type":"heading","text":"mapFailureToSuccess","anchor":"mapFailureToSuccess","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"This idea only works when the "},{"type":"codeVoice","code":"Failure"},{"type":"text","text":" type is going to be “removed”, which is represented by "},{"type":"codeVoice","code":"Never"},{"type":"text","text":". So, there’s no point in offering a "},{"type":"codeVoice","code":"flatMapFailureToSuccess"},{"type":"text","text":", as "},{"type":"codeVoice","code":"Result.failure"},{"type":"text","text":"s can’t be created with if their "},{"type":"codeVoice","code":"Failure"},{"type":"text","text":" is "},{"type":"codeVoice","code":"Never"},{"type":"text","text":"."}]},{"type":"heading","text":"mapFailureToSuccessAndErrorToFailure","anchor":"mapFailureToSuccessAndErrorToFailure","level":4},{"type":"paragraph","inlineContent":[{"text":"This is a niche type of error mapping operation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It’s similar to the two “"},{"type":"codeVoice","code":"…AndMergeError"},{"type":"text","text":"” methods in that an error thrown from transforming will become a "},{"type":"codeVoice","code":"failure"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"But it’s dissimilar in that while the error thrown "},{"type":"emphasis","inlineContent":[{"type":"text","text":"can"}]},{"type":"text","text":" be "},{"code":"Failure","type":"codeVoice"},{"type":"text","text":", there’s no requirement of that (and it’s likely to be a rare case). So, calling this "},{"code":"mapFailureToSuccessAndMergeError","type":"codeVoice"},{"type":"text","text":" would not generally be accurate."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/hmresult\/mapping-methods"]}],"kind":"article","references":{"doc://HMResult/documentation/HMResult/Swift/Result/mapFailureToSuccess(_:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"mapFailureToSuccess","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Error","kind":"genericParameter"},{"text":">((","kind":"text"},{"text":"Failure","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":"(","kind":"text"},{"text":"Error","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Success","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":"(","kind":"text"},{"text":"Error","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Result","kind":"typeIdentifier","preciseIdentifier":"s:s6ResultO"},{"text":"<","kind":"text"},{"text":"Success","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Never","kind":"typeIdentifier","preciseIdentifier":"s:s5NeverO"},{"text":">","kind":"text"}],"title":"mapFailureToSuccess(_:)","identifier":"doc:\/\/HMResult\/documentation\/HMResult\/Swift\/Result\/mapFailureToSuccess(_:)","abstract":[{"text":"Transform failures into successes.","type":"text"}],"role":"symbol","type":"topic","conformance":{"constraints":[{"type":"codeVoice","code":"Failure"},{"text":" conforms to ","type":"text"},{"type":"codeVoice","code":"Error"},{"text":".","type":"text"}],"conformancePrefix":[{"text":"Conforms when","type":"text"}],"availabilityPrefix":[{"text":"Available when","type":"text"}]},"url":"\/documentation\/hmresult\/swift\/result\/mapfailuretosuccess(_:)","kind":"symbol"},"doc://HMResult/documentation/HMResult/Swift/Result/flatMapAndMergeError(_:)":{"kind":"symbol","url":"\/documentation\/hmresult\/swift\/result\/flatmapandmergeerror(_:)","title":"flatMapAndMergeError(_:)","type":"topic","abstract":[{"text":"Transform successes.","type":"text"}],"conformance":{"availabilityPrefix":[{"type":"text